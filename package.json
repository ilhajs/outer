{
  "name": "outer-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "test": "bun run --filter './packages/*' test",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "cleanup": "bun run --parallel --filter '*' cleanup && rimraf node_modules bun.lock"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "bun": "1.3.14"
  }
}
