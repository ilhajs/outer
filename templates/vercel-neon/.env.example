DATABASE_URL=

# Added to the project when you create a Blob store — `vercel env pull` fetches it locally
BLOB_READ_WRITE_TOKEN=

BASE_URL=http://localhost:3000
AUTH_SECRET=dev-only-secret
# seeded admin account (signs in via email OTP, no password) — `npm run migrate` seeds it; leave unset to skip
ADMIN_EMAIL=admin@example.com
# unique per instance — keeps this instance's session cookies separate from other Outer
# instances on the same host (e.g. multiple localhost ports opened from the hub)
COOKIE_PREFIX=outer-vercel
# comma-separated browser origins allowed cross-origin (e.g. an admin dashboard)
CORS_ORIGINS=https://hub.outer.now
