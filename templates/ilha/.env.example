VITE_APP_URL=http://localhost:3000
NITRO_AUTH_SECRET=
# seeded admin account (signs in via email OTP); leave unset to skip seeding
ADMIN_EMAIL=admin@example.com
# unique per instance — keeps this instance's session cookies separate from other Outer
# instances on the same host (e.g. multiple localhost ports opened from the hub)
COOKIE_PREFIX=outer-ilha
# comma-separated browser origins allowed cross-origin (e.g. an admin dashboard)
CORS_ORIGINS=https://hub.outer.now
