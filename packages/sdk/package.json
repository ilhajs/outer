{
  "name": "@outerjs/sdk",
  "version": "0.1.0",
  "description": "Type-safe client for Outer servers — merges an oRPC client with an opt-in Better Auth client",
  "keywords": [
    "authentication",
    "better-auth",
    "client",
    "orpc",
    "sdk"
  ],
  "homepage": "https://github.com/ilhajs/outer#readme",
  "bugs": {
    "url": "https://github.com/ilhajs/outer/issues"
  },
  "license": "MIT",
  "author": "Ryuz <ryuzer@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilhajs/outer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsdown",
    "test": "bun test --parallel --timeout 60000"
  },
  "dependencies": {
    "@orpc/client": "2.0.0-beta.18",
    "@orpc/server": "2.0.0-beta.18",
    "better-auth": "1.6.24"
  }
}
