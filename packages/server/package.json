{
  "name": "@outerjs/server",
  "version": "0.1.0",
  "description": "The tiny backend you never knew you needed",
  "keywords": [
    "authentication",
    "backend",
    "better-auth",
    "kysely",
    "orpc",
    "pglite",
    "postgres"
  ],
  "homepage": "https://github.com/ilhajs/outer#readme",
  "bugs": {
    "url": "https://github.com/ilhajs/outer/issues"
  },
  "license": "MIT",
  "author": "Ryuz <ryuzer@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilhajs/outer.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./pglite": {
      "types": "./dist/pglite.d.mts",
      "import": "./dist/pglite.mjs"
    },
    "./schema": {
      "types": "./dist/schema.d.mts",
      "import": "./dist/schema.mjs"
    },
    "./secrets": {
      "types": "./dist/secrets.d.mts",
      "import": "./dist/secrets.mjs"
    },
    "./storage": {
      "types": "./dist/storage.d.mts",
      "import": "./dist/storage.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && tsdown",
    "test": "bun test --parallel --timeout 60000",
    "test:e2e": "bun test/index.ts"
  },
  "dependencies": {
    "@orpc/client": "2.0.0-beta.19",
    "@orpc/server": "2.0.0-beta.19",
    "better-auth": "1.6.25",
    "h3": "^2.0.1-rc.25",
    "kysely": "0.29.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@better-auth/api-key": "1.6.25",
    "@electric-sql/pglite": "0.5.4",
    "@electric-sql/pglite-pgvector": "0.0.5",
    "@orpc/openapi": "2.0.0-beta.19",
    "@orpc/zod": "2.0.0-beta.19",
    "orpc-mcp": "0.1.1",
    "srvx": "^0.12.4",
    "unstorage": "2.0.0-alpha.7"
  },
  "peerDependencies": {
    "@better-auth/api-key": "^1.6.25",
    "@electric-sql/pglite": "0.5.4",
    "@electric-sql/pglite-pgvector": "0.0.5",
    "@orpc/openapi": "2.0.0-beta.19",
    "@orpc/zod": "2.0.0-beta.19",
    "orpc-mcp": "^0.1.1"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    },
    "@electric-sql/pglite-pgvector": {
      "optional": true
    },
    "@orpc/openapi": {
      "optional": true
    },
    "@orpc/zod": {
      "optional": true
    },
    "orpc-mcp": {
      "optional": true
    },
    "@better-auth/api-key": {
      "optional": true
    }
  }
}
